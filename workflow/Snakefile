rule raw_stats:
    """
    Statistiques des reads bruts avant tout filtrage.
    """
    input:
        reads = lambda wc: config["samples"][wc.sample]["reads"]
    output:
        stats = temp("results/stats/{sample}_raw_stats.txt")
    log:
        "logs/stats/{sample}_raw.log"
    conda:
        "envs/minimap2.yaml"
    shell:
        """
        mkdir -p results/stats
        seqkit stats -a {input.reads} > {output.stats} 2> {log}
        """








# ─────────────────────────────────────────
# ÉTAPE 1 — Filtrage faible complexité
# ─────────────────────────────────────────

rule dustmasker_filter:
    input:
        reads=lambda wc: config["samples"][wc.sample]["reads"]
    output:
        reads=temp("results/dustmasker/{sample}.fastq")
    log:
        "logs/dustmasker/{sample}.log"
    conda:
        "envs/blast.yaml"
    shell:
        r"""
        set -euo pipefail

        TMP_FASTA=results/dustmasker/{wildcards.sample}_tmp.fasta
        MASKED_FASTA=results/dustmasker/{wildcards.sample}_masked.fasta

        mkdir -p results/dustmasker logs/dustmasker

        echo "Conversion FASTQ -> FASTA" > {log}

        awk '
            NR % 4 == 1 {{
                header = substr($0, 2)
                split(header, a, " ")
                print ">" a[1]
            }}
            NR % 4 == 2 {{ print }}
        ' {input.reads} > $TMP_FASTA

        echo "dustmasker..." >> {log}

        dustmasker \
            -in $TMP_FASTA \
            -outfmt fasta \
            > $MASKED_FASTA \
            2>> {log}

        echo "Filtrage..." >> {log}

        awk '
            BEGIN {{ FS = "\n" }}

            FNR == NR {{
                if ($0 ~ /^>/) {{
                    if (seq_id != "") {{
                        total = length(seq)
                        n_lower = 0; max_run = 0; current_run = 0
                        for (i = 1; i <= total; i++) {{
                            base = substr(seq, i, 1)
                            if (base ~ /[a-z]/) {{
                                n_lower++; current_run++
                                if (current_run > max_run) max_run = current_run
                            }} else {{ current_run = 0 }}
                        }}
                        frac = n_lower / total
                        if (frac <= 0.5 && max_run <= 50) keep[seq_id] = 1
                    }}
                    seq_id = substr($0, 2)
                    split(seq_id, a, " "); seq_id = a[1]; seq = ""
                }} else {{ seq = seq $0 }}
                next
            }}

            {{
                mod = FNR % 4
                if (mod == 1) {{
                    header = substr($0, 2)
                    split(header, a, " "); current_id = a[1]
                }}
                if (current_id in keep) print
            }}

            END {{
                if (seq_id != "") {{
                    total = length(seq)
                    n_lower = 0; max_run = 0; current_run = 0
                    for (i = 1; i <= total; i++) {{
                        base = substr(seq, i, 1)
                        if (base ~ /[a-z]/) {{
                            n_lower++; current_run++
                            if (current_run > max_run) max_run = current_run
                        }} else {{ current_run = 0 }}
                    }}
                    frac = n_lower / total
                    if (frac <= 0.4 && max_run <= 20) keep[seq_id] = 1
                }}
            }}
        ' $MASKED_FASTA {input.reads} > {output.reads}

        rm -f $TMP_FASTA $MASKED_FASTA
        echo "Reads après filtre complexité : $(grep -c '^@' {output.reads})" >> {log}
        """


# ─────────────────────────────────────────
# ÉTAPE 2 — Kraken2
# ─────────────────────────────────────────

rule kraken2_classify:
    input:
        reads = "results/dustmasker/{sample}.fastq",
        db    = config["kraken2_db"]
    output:
        report     = "results/kraken2/{sample}.kreport2",
        kraken_out = temp("results/kraken2/{sample}.kraken2")
    log:
        "logs/kraken2/{sample}.log"
    threads: config.get("threads", 8)
    conda:
        "envs/kraken2.yaml"
    params:
        confidence         = 0.05,
        minimum_hit_groups = 3,
    shell:
        """
        kraken2 \
            --db {input.db} \
            --memory-mapping \
            --threads {threads} \
            --confidence {params.confidence} \
            --minimum-hit-groups {params.minimum_hit_groups} \
            --report {output.report} \
            --output {output.kraken_out} \
            {input.reads} \
            2> {log}
        """


