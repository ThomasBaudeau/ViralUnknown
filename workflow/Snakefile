rule merge_assembly_clusters:
    """
    Merge MetaFlye contigs + MMseqs representatives.
    - MetaFlye IDs  : >assembly_<originalID>
    - MMseqs IDs    : >cluster_<nbReadsInCluster>_<representativeID>
    """
    input:
        assembly = "results/metaflye/{sample}/assembly.fasta",
        clusters = "results/mmseqs/{sample}/clusters_rep_seq.fasta",
        summary  = "results/mmseqs/{sample}/clusters_summary.tsv",
    output:
        merged = temp("results/blast_input/{sample}_candidates.fasta"),
    log:
        "logs/blast_input/{sample}.log"
    conda:
        "envs/mmseqs2.yaml"
    script:
        "scripts/merge_fasta.py"


rule blast_candidates:
    input:
        fasta = "results/blast_input/{sample}_candidates.fasta",
        nhr   = config["blast_db"] + ".nhr",
    output:
        results = temp("results/blast/{sample}_blast_results.tsv"),
    log:
        "logs/blast/{sample}.log"
    threads: config.get("threads", 8)
    conda:
        "envs/blast.yaml"
    params:
        blast_db        = config["blast_db"],
        blast_db_dir    = str(Path(config["blast_db"]).parent),
        evalue          = config.get("blast_evalue", "1e-5"),
        max_target_seqs = config.get("blast_max_hits", 5),
    shell:
        r"""
        mkdir -p results/blast

        export BLASTDB={params.blast_db_dir}

        blastn \
            -query {input.fasta} \
            -db {params.blast_db} \
            -out {output.results} \
            -outfmt "6 qseqid sseqid pident qcovs length evalue bitscore stitle" \
            -evalue {params.evalue} \
            -max_target_seqs {params.max_target_seqs} \
            -num_threads {threads} \
            2> {log}

        echo "BLAST hits : $(wc -l < {output.results})" >> {log}
        """

rule filter_blast_candidates:
    input:
        fasta = "results/blast_input/{sample}_candidates.fasta",
        blast = "results/blast/{sample}_blast_results.tsv",
    output:
        report = temp("results/blast/{sample}_blast_summary.tsv"),
    log:
        "logs/blast/{sample}_filter.log"
    conda:
        "envs/mmseqs2.yaml"
    params:
        min_pident = 80,
        min_qcov   = 80,
    shell:
        """
        mkdir -p results/blast

        ALL_IDS=/tmp/{wildcards.sample}_all_ids.txt
        BEST_HITS=/tmp/{wildcards.sample}_best_hits.tsv

        # ---------- All FASTA IDs ----------
        grep '^>' {input.fasta} \
                | sed 's/^>//' \
                | awk '{{print $1}}' \
                | sort -u \
                > $ALL_IDS

        echo "FASTA sequences uniques : $(wc -l < $ALL_IDS)" > {log}
        echo "BLAST lignes totales    : $(wc -l < {input.blast})" >> {log}

        # ---------- Meilleur hit unique par query ----------
        # Pour chaque query, on garde la ligne avec le meilleur score combiné pident+qcov
        awk -F '\\t' '
            {{
                q = $1
                score = $3 + $4
                if (score > best_score[q]) {{
                    best_score[q] = score
                    best_line[q]  = $0
                }}
            }}
            END {{
                for (q in best_line)
                    print best_line[q]
            }}
        ' {input.blast} | sort -k1,1 > $BEST_HITS

        echo "Queries uniques dans BLAST : $(wc -l < $BEST_HITS)" >> {log}

        # ---------- Report ----------
        printf "qseqid\\tstatus\\tpident\\tqcov\\tbest_hit\\n" > {output.report}

        # Reads avec hit → statut selon seuils
        awk -F '\\t' -v pident={params.min_pident} -v qcov={params.min_qcov} '
            BEGIN {{ OFS="\\t" }}
            {{
                if ($3 >= pident && $4 >= qcov)
                    status = "excluded"
                else
                    status = "kept_bad_hit"
                print $1, status, $3, $4, $2
            }}
        ' $BEST_HITS >> {output.report}

        # Reads absents du BLAST → no_hit
        comm -23 $ALL_IDS <(awk '{{print $1}}' $BEST_HITS | sort -u) \
            | awk 'BEGIN{{OFS="\\t"}} {{print $1, "kept_no_hit", 0, 0, "."}}' \
            >> {output.report}

        echo "Excluded    : $(grep -c "excluded"     {output.report} || true)" >> {log}
        echo "Bad hit     : $(grep -c "kept_bad_hit" {output.report} || true)" >> {log}
        echo "No hit      : $(grep -c "kept_no_hit"  {output.report} || true)" >> {log}
        echo "Total lignes summary (sans header) : $(tail -n +2 {output.report} | wc -l)" >> {log}

        rm -f $ALL_IDS $BEST_HITS
        """

rule blast_fasta:
    input:
        fasta   = "results/blast_input/{sample}_candidates.fasta",
        blast   = "results/blast/{sample}_blast_summary.tsv",
    output:
        filtered = "results/blast/{sample}_candidates_filtered.fasta",
        excluded = "results/blast/{sample}_candidates_excluded.fasta",
    log:
        "logs/blast/{sample}_filter.log"
    conda:
        "envs/mmseqs2.yaml"
    script:
        "scripts/blast_fasta.py"


rule merge_blast_filterd:
    input:
        filtered = expand("results/blast/{sample}_candidates_filtered.fasta", sample=SAMPLES)
    output:
        merged = "results/blast/all_merged_blast.fasta",
    log:
        "logs/blast/merge_filtered.log"
    conda:
       "envs/mmseqs2.yaml"
    shell:
        """
        mkdir -p results/blast

        # Merger tous les FASTA en préfixant les IDs par le nom du sample
        for fasta in {input.filtered}; do
            sample=$(basename "$fasta" _candidates_filtered.fasta)
            seqkit replace \
                -p "^" \
                -r "${{sample}}__" \
                "$fasta" \
                2>> {log}
        done > {output.merged}

        echo "Total sequences merged : $(grep -c '^>' {output.merged})" >> {log}
        """

rule mmseqs_blast_cluster:
    input:
        reads = "results/blast/all_merged_blast.fasta",
    output:
        rep_seq = "results/mmseqs_blast/clusters_rep_seq.fasta",
        tsv     = temp("results/mmseqs_blast/clusters_cluster.tsv"),
        summary = "results/mmseqs_blast/clusters_summary.tsv",
    log:
        "logs/mmseqs_blast/blast.log"
    threads: config.get("threads", 8)
    conda:
        "envs/mmseqs2.yaml"
    params:
        min_seq_id = config.get("mmseqs_min_seq_id", 0.80),
        outdir     = "results/mmseqs_blast/",
        tmpdir     = "/tmp/mmseqs_blast"
    shell:
        """
        mkdir -p {params.outdir} {params.tmpdir}

        n_reads=$(grep -c "^>" {input.reads} || true)
        echo "Reads à clusteriser : $n_reads" >> {log}

        if [ "$n_reads" -lt 2 ]; then
            echo "Pas assez de reads" >> {log}
            touch {output.rep_seq} {output.tsv} {output.summary}
            exit 0
        fi

        seqkit fq2fa {input.reads} \
            > {params.tmpdir}/reads.fasta 2>> {log}

        mmseqs easy-cluster \
            {params.tmpdir}/reads.fasta \
            {params.outdir}/clusters \
            {params.tmpdir} \
            --min-seq-id {params.min_seq_id} \
            --threads {threads} \
            --cov-mode 1 \
            -c 0.8 \
            2>> {log}

        # Extraire les représentants si non générés
        if [ ! -s {output.rep_seq} ]; then
            awk '{{print $1}}' {output.tsv} | \
                sort -u > {params.tmpdir}/rep_ids.txt
            seqkit grep \
                -f {params.tmpdir}/rep_ids.txt \
                {params.outdir}/clusters_all_seqs.fasta | \
            seqkit rmdup \
                -o {output.rep_seq}
        fi

        # Générer le fichier résumé :
        # representant | nb_membres | ids_membres
        awk '
            BEGIN {{
                OFS = "\t"
                print "representant", "nb_membres", "membres"
            }}
            {{
                rep = $1
                member = $2
                members[rep] = members[rep] (members[rep] ? "," : "") member
                count[rep]++
            }}
            END {{
                for (rep in count)
                    print rep, count[rep], members[rep]
            }}
        ' {output.tsv} | sort -t$'\t' -k2 -rn \
            > {output.summary}

        echo "Clusters : $(tail -n +2 {output.summary} | wc -l)" >> {log}
        echo "Représentants extraits : $(grep -c '^>' {output.rep_seq})" >> {log}

        rm -rf {params.tmpdir}
        """

rule generate_report:
    input:
        expand("results/mmseqs/{sample}/clusters_rep_seq.fasta", sample=SAMPLES),
        expand("results/fastqc/{sample}_not_mapped_fastqc.html", sample=SAMPLES),
    output:
        "results/report.html"
    log:
        "logs/report.log"
    shell:
        """
        viralunknown report \
            --config config.yaml \
            --output {output} \
            2> {log}
        """