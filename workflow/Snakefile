# ─────────────────────────────────────────

rule extract_unclassified:
    input:
        kraken_out = "results/kraken2/{sample}.kraken2",
        report     = "results/kraken2/{sample}.kreport2",
        reads      = "results/dustmasker/{sample}.fastq",
    output:
        reads = "results/unclassified/{sample}.fastq",
    log:
        "logs/unclassified/{sample}.log"
    conda:
        "envs/krakentools.yaml"
    params:
        taxid = 0
    shell:
        """
        extract_kraken_reads.py \
            -k {input.kraken_out} \
            -s {input.reads} \
            -t {params.taxid} \
            -o {output.reads} \
            -r {input.report} \
            --fastq-output \
            2> {log}
        echo "Reads non classifiés : $(grep -c '^@' {output.reads})" >> {log}
        """


# ─────────────────────────────────────────
# ÉTAPE 4 — Assembly MetaFlye
# ─────────────────────────────────────────

rule metaflye_assembly:
    input:
        reads = "results/unclassified/{sample}.fastq"
    output:
        assembly = "results/metaflye/{sample}/assembly.fasta"
    log:
        "logs/metaflye/{sample}.log"
    threads: config.get("threads", 8)
    conda:
        "envs/flye.yaml"
    params:
        outdir = "results/metaflye/{sample}"
    shell:
        """
        mkdir -p {params.outdir}
        flye \
            --nano-raw {input.reads} \
            --meta \
            --threads {threads} \
            --min-overlap 1000 \
            --out-dir {params.outdir} \
            > {log} 2>&1
        """


# ─────────────────────────────────────────
# ÉTAPE 5 — Reads non mappés MetaFlye
#           + séparation longs / courts
# ─────────────────────────────────────────

rule unmapped_after_metaflye:
    input:
        assembly = "results/metaflye/{sample}/assembly.fasta",
        reads    = "results/unclassified/{sample}.fastq"
    output:
        not_mapped  = "results/final/metaflye/{sample}_not_mapped.fastq",
        short_reads = "results/final/metaflye/{sample}_short_reads.fastq",
    log:
        "logs/metaflye/{sample}_mapping.log"
    threads: config.get("threads", 8)
    conda:
        "envs/minimap2.yaml"
    params:
        min_len = config.get("min_read_length_assembly", 500)
    shell:
        """
        mkdir -p results/final/metaflye

        minimap2 \
            -ax map-ont \
            --secondary=no \
            -t {threads} \
            {input.assembly} \
            {input.reads} | \
        samtools fastq -f 4 - \
            > {output.not_mapped} \
            2> {log}

        echo "Reads non mappés : $(grep -c '^@' {output.not_mapped})" >> {log}

        # Garder les courts de côté
        seqkit seq \
            --max-len {params.min_len} \
            {output.not_mapped} \
            -o {output.short_reads} 2>> {log}

        echo "Reads courts (<{params.min_len}bp) : $(grep -c '^@' {output.short_reads})" >> {log}
        """





rule filter_low_quality:
    """
    Filtre les reads par score de qualité moyen.
    Les reads avec Q < 10 sont mis de côté dans un fichier séparé.
    Q10 = 90% de précision par base (seuil standard Nanopore)
    """
    input:
        reads = "results/final/metaflye/{sample}_not_mapped.fastq"
    output:
        high_qual = "results/quality_filter/{sample}_not_mapped_highQ.fastq",
        low_qual  = "results/quality_filter/{sample}_not_mapped_lowQ.fastq",
    log:
        "logs/quality_filter/{sample}.log"
    conda:
        "envs/mmseqs2.yaml"
    params:
        min_qual = config.get("min_quality", 10)
    shell:
        """
        mkdir -p results/quality_filter

        # Reads de haute qualité (Q >= 10)
        seqkit seq \
            --min-qual {params.min_qual} \
            {input.reads} \
            -o {output.high_qual} \
            2> {log}

        # Reads de basse qualité (Q < 10)
        seqkit seq \
            --max-qual {params.min_qual} \
            {input.reads} \
            -o {output.low_qual} \
            2>> {log}

        echo "High quality reads  (Q>={params.min_qual}) : $(grep -c '^@' {output.high_qual})" >> {log}
        echo "Low quality reads (Q<{params.min_qual})  : $(grep -c '^@' {output.low_qual})" >> {log}
        """






# ─────────────────────────────────────────
# ÉTAPE 6 — MMseqs2 clustering
# ─────────────────────────────────────────

rule mmseqs_cluster:
    input:
        reads = "results/quality_filter/{sample}_not_mapped_highQ.fastq",
    output:
        rep_seq = "results/mmseqs/{sample}/clusters_rep_seq.fasta",
        tsv     = "results/mmseqs/{sample}/clusters_cluster.tsv",
        summary = "results/mmseqs/{sample}/clusters_summary.tsv",
    log:
        "logs/mmseqs/{sample}.log"
    threads: config.get("threads", 8)
    conda:
        "envs/mmseqs2.yaml"
    params:
        min_seq_id = config.get("mmseqs_min_seq_id", 0.80),
        outdir     = "results/mmseqs/{sample}",
        tmpdir     = "/tmp/mmseqs_{sample}"
    shell:
        """
        mkdir -p {params.outdir} {params.tmpdir}

        n_reads=$(grep -c "^@" {input.reads} || true)
        echo "Reads à clusteriser : $n_reads" >> {log}

        if [ "$n_reads" -lt 2 ]; then
            echo "Pas assez de reads" >> {log}
            touch {output.rep_seq} {output.tsv} {output.summary}
            exit 0
        fi

        seqkit fq2fa {input.reads} \
            > {params.tmpdir}/reads.fasta 2>> {log}

        mmseqs easy-cluster \
            {params.tmpdir}/reads.fasta \
            {params.outdir}/clusters \
            {params.tmpdir} \
            --min-seq-id {params.min_seq_id} \
            --threads {threads} \
            --cov-mode 1 \
            -c 0.8 \
            2>> {log}

        # Extraire les représentants si non générés
        if [ ! -s {output.rep_seq} ]; then
            awk '{{print $1}}' {output.tsv} | \
                sort -u > {params.tmpdir}/rep_ids.txt
            seqkit grep \
                -f {params.tmpdir}/rep_ids.txt \
                {params.outdir}/clusters_all_seqs.fasta | \
            seqkit rmdup \
                -o {output.rep_seq}
        fi

        # Générer le fichier résumé :
        # representant | nb_membres | ids_membres
        awk '
            BEGIN {{
                OFS = "\t"
                print "representant", "nb_membres", "membres"
            }}
            {{
                rep = $1
                member = $2
                members[rep] = members[rep] (members[rep] ? "," : "") member
                count[rep]++
            }}
            END {{
                for (rep in count)
                    print rep, count[rep], members[rep]
            }}
        ' {output.tsv} | sort -t$'\t' -k2 -rn \
            > {output.summary}

        echo "Clusters : $(tail -n +2 {output.summary} | wc -l)" >> {log}
        echo "Représentants extraits : $(grep -c '^>' {output.rep_seq})" >> {log}

        rm -rf {params.tmpdir}
        """

