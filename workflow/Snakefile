    log:
        "logs/report.log"
    shell:
        """
        viralunknown report \
            --config config.yaml \
            --output {output} \
            2> {log}
        """

rule merge_assembly_clusters:
    """
    Merges metaFlye assembly contigs and MMseqs2 cluster
    representatives into a single FASTA file for BLAST.
    """
    input:
        assembly = "results/metaflye/{sample}/assembly.fasta",
        clusters = "results/mmseqs/{sample}/clusters_rep_seq.fasta",
    output:
        merged = "results/blast_input/{sample}_candidates.fasta",
    log:
        "logs/blast_input/{sample}.log"
    conda:
        "envs/seqkit.yaml"
    shell:
        """
        mkdir -p results/blast_input

        # Préfixer les IDs pour distinguer l'origine
        seqkit replace \
            -p "^" \
            -r "assembly_{wildcards.sample}__" \
            {input.assembly} \
            2>> {log} > results/blast_input/{wildcards.sample}_assembly_prefixed.fasta

        seqkit replace \
            -p "^" \
            -r "cluster_{wildcards.sample}__" \
            {input.clusters} \
            2>> {log} > results/blast_input/{wildcards.sample}_clusters_prefixed.fasta

        # Fusionner et dédupliquer
        cat \
            results/blast_input/{wildcards.sample}_assembly_prefixed.fasta \
            results/blast_input/{wildcards.sample}_clusters_prefixed.fasta | \
        seqkit rmdup \
            -o {output.merged} \
            2>> {log}

        # Nettoyer les fichiers temporaires
        rm -f results/blast_input/{wildcards.sample}_assembly_prefixed.fasta \
              results/blast_input/{wildcards.sample}_clusters_prefixed.fasta

        echo "Assembly contigs  : $(grep -c '^>' {input.assembly})"  >> {log}
        echo "Cluster reps      : $(grep -c '^>' {input.clusters})"  >> {log}
        echo "Total merged      : $(grep -c '^>' {output.merged})"   >> {log}
        """


