rule extract_non_human:
    input:
        kraken_out = "results/kraken2/{sample}.kraken2",
        report     = "results/kraken2/{sample}.kreport2",
        reads      = "results/dustmasker/{sample}.fastq",
    output:
        reads = temp("results/non_human/{sample}.fastq"),
    log:
        "logs/extract/{sample}.log"
    conda:
        "envs/krakentools.yaml"
    params:
        taxids = "9606 131567 2 2759 4751"
    shell:
        """
        extract_kraken_reads.py \
            -k {input.kraken_out} \
            -s {input.reads} \
            -t {params.taxids} \
            -o {output.reads} \
            -r {input.report} \
            --include-children \
            --exclude \
            --fastq-output \
            2> {log}
        echo "Reads non humains : $(grep -c '^@' {output.reads})" >> {log}
        """


